{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/session-start.py",
        "timeout": 10
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/drop.py",
        "timeout": 3
      }
    ],
    "postToolUse": [
      {
        "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/feedback.py",
        "timeout": 5
      }
    ],
    "stop": [
      {
        "command": "python3 ${CURSOR_PLUGIN_ROOT}/hooks/stop.py",
        "timeout": 5
      }
    ]
  }
}
