{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "python3 .github/hooks/session-start.py",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "python3 .github/hooks/feedback.py",
        "timeoutSec": 5
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "python3 .github/hooks/stop.py",
        "timeoutSec": 5
      }
    ]
  }
}
